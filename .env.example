# EWU Portal - Environment Variables (copy to .env and fill in values)

# Flask secret key (change this in production!)
SECRET_KEY=ewu_secret_key_123

# Database URL
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///ewu_portal.db

# PostgreSQL (uncomment and fill in if you have PostgreSQL installed):
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ewu_portal
